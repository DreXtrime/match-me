# -------------------------------------------------------
# Local development (H2 in-memory) — no changes needed
# Just run ./mvnw spring-boot:run and it works out of the box
# -------------------------------------------------------

PORT=3000
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRATION=86400000
SHOW_SQL=false

# Drop and recreate all tables on every startup (H2 default — comment out when using PostgreSQL)
# DDL_AUTO=create-drop

# Fill the database with mock users on startup
SEED_DATABASE=true
SEED_USER_COUNT=200

# -------------------------------------------------------
# PostgreSQL (production) — fill in below
# -------------------------------------------------------

DATABASE_URL=jdbc:postgresql://localhost:5433/matchme
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DRIVER=org.postgresql.Driver
DDL_AUTO=update
