# -------------------------------------------------------
# SERVER CONFIGURATION
# -------------------------------------------------------

PORT=3000
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRATION=86400000
SHOW_SQL_QUERIES=false

# Uncomment these to fill the database with mock users on startup
# SEED_DATABASE=true
# SEED_USER_COUNT=200

# -------------------------------------------------------
# DATABASE SELECTION
# By default H2 - in-memory database is used.
# -------------------------------------------------------

# Default: H2 In-Memory Database.
# To use PostgreSQL, uncomment ALL lines below and configure your credentials.

# DATABASE_URL=jdbc:postgresql://localhost:5433/matchme
# DB_USERNAME=postgres
# DB_PASSWORD=postgres
# DB_DRIVER=org.postgresql.Driver

# When running H2, this defaults to 'create-drop' (wiped on every restart).
# Uncomment this line when switching to PostgreSQL to preserve your data.
# DDL_AUTO=update

